<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/relativeLayout1"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B6481"
    android:padding="8dip">

    <ImageView
        android:id="@+id/imageView1"
        android:layout_width="116dp"
        android:layout_height="82dp"
        android:layout_alignParentStart="true"
        android:layout_marginTop="43dp"
        android:layout_marginStart="5dp"
        android:src="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/textView1"
        android:layout_width="325dp"
        android:layout_height="60dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="62dp"
        android:gravity="center_horizontal"
        android:text="@string/activity_a"
        android:textColor="@android:color/background_light"
        android:textSize="30sp" />

    <Button
        android:id="@+id/btn_start_b"
        android:layout_width="136dp"
        android:layout_height="64dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="22dp"
        android:layout_marginTop="150dp"
        android:background="#F5F8F11E"
        android:onClick="startActivityB"
        android:text="Activity B" />

    <Button
        android:id="@+id/btn_start_dialog"
        android:layout_width="136dp"
        android:layout_height="64dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="150dp"
        android:background="#F5F8F11E"
        android:onClick="startDialog"
        android:text="Dialog" />

    <Button
        android:id="@+id/btn_start_c"
        android:layout_width="136dp"
        android:layout_height="64dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="230dp"
        android:background="#F5F8F11E"
        android:onClick="startActivityC"
        android:text="Activity C" />

    <TextView
        android:id="@+id/threadCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="310dp"
        android:text="Thread Counter: 0000"
        android:textColor="@android:color/background_light"
        android:textSize="25sp" />

    <TextView
        android:id="@+id/pauseCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/threadCounter"
        android:layout_marginTop="10dp"
        android:text="OnPause Counter: 0000"
        android:textColor="@android:color/background_light"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/destroyCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/pauseCounter"
        android:layout_marginTop="10dp"
        android:text="OnDestroy Counter: 0000"
        android:textColor="@android:color/background_light"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_finish_a"
        android:layout_width="141dp"
        android:layout_height="60dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="50dp"
        android:background="@android:color/background_dark"
        android:onClick="finishActivityA"
        android:text="Close App"
        android:textColor="@android:color/background_light"
        android:textSize="18sp" />

</RelativeLayout>
